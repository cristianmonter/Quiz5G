<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quiz — O Povo Brasileiro</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&family=Nunito+Sans:wght@400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #1a1a2e;
    --card: #16213e;
    --accent: #e94560;
    --yellow: #f5a623;
    --green: #2ecc71;
    --blue: #3498db;
    --purple: #9b59b6;
    --red: #e74c3c;
    --text: #ffffff;
    --muted: #a0aec0;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Nunito Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 16px;
    overflow-x: hidden;
  }
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 20% 30%, rgba(255,255,255,.15) 0%, transparent 100%),
      radial-gradient(1px 1px at 70% 15%, rgba(255,255,255,.12) 0%, transparent 100%),
      radial-gradient(1px 1px at 50% 80%, rgba(255,255,255,.10) 0%, transparent 100%),
      radial-gradient(1px 1px at 85% 60%, rgba(255,255,255,.08) 0%, transparent 100%);
    pointer-events: none;
    z-index: 0;
  }
  .wrap { position: relative; z-index: 1; width: 100%; max-width: 700px; }

  /* SPLASH */
  #splash { text-align: center; animation: fadeIn .6s ease; }
  #splash .emoji { font-size: 64px; margin-bottom: 12px; }
  #splash h1 {
    font-family: 'Nunito', sans-serif;
    font-size: clamp(28px, 6vw, 48px);
    font-weight: 900;
    background: linear-gradient(135deg, #f5a623, #e94560);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1.1;
    margin-bottom: 8px;
  }
  #splash p { color: var(--muted); font-size: 16px; margin-bottom: 28px; }
  .info-box {
    background: var(--card);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 16px;
    padding: 20px 24px;
    margin-bottom: 28px;
    text-align: left;
  }
  .info-box div { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; font-size: 15px; color: var(--muted); }
  .info-box div:last-child { margin-bottom: 0; }
  .info-box span.icon { font-size: 20px; }
  .info-box strong { color: #fff; }

  /* TAGS */
  .tag-row { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-bottom: 28px; }
  .tag {
    padding: 5px 13px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
    font-family: 'Nunito', sans-serif;
    letter-spacing: .03em;
  }
  .tag-ind { background: rgba(46,204,113,.15); border: 1px solid #2ecc71; color: #2ecc71; }
  .tag-afr { background: rgba(231,76,60,.15); border: 1px solid #e74c3c; color: #e74c3c; }
  .tag-eur { background: rgba(52,152,219,.15); border: 1px solid #3498db; color: #3498db; }
  .tag-asi { background: rgba(155,89,182,.15); border: 1px solid #9b59b6; color: #9b59b6; }

  /* PROGRESS */
  .progress-wrap {
    height: 6px;
    background: rgba(255,255,255,.08);
    border-radius: 6px;
    margin-bottom: 20px;
    overflow: hidden;
  }
  .progress-bar {
    height: 100%;
    background: linear-gradient(90deg, #e94560, #f5a623);
    border-radius: 6px;
    transition: width .4s ease;
  }

  /* TOP BAR */
  #quiz { animation: fadeIn .4s ease; }
  .top-bar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
  .q-counter { font-family: 'Nunito', sans-serif; font-size: 14px; font-weight: 800; color: var(--muted); letter-spacing: .05em; text-transform: uppercase; }
  .score-badge { background: linear-gradient(135deg, #f5a623, #e94560); border-radius: 20px; padding: 4px 14px; font-family: 'Nunito', sans-serif; font-size: 14px; font-weight: 800; }

  /* CATEGORY BADGE */
  .cat-badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 700;
    font-family: 'Nunito', sans-serif;
    margin-bottom: 14px;
    letter-spacing: .04em;
    text-transform: uppercase;
  }

  /* TIMER */
  .timer-wrap { position: relative; height: 8px; background: rgba(255,255,255,.1); border-radius: 8px; margin-bottom: 24px; overflow: hidden; }
  .timer-bar { height: 100%; border-radius: 8px; background: linear-gradient(90deg, #2ecc71, #f5a623, #e94560); transition: width .1s linear; }
  .timer-num { text-align: center; font-family: 'Nunito', sans-serif; font-size: 28px; font-weight: 900; margin-bottom: 10px; transition: color .3s; }

  /* QUESTION */
  .q-card {
    background: var(--card);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 20px;
    padding: 24px 24px 20px;
    margin-bottom: 20px;
    text-align: center;
  }
  .q-card .q-emoji { font-size: 34px; margin-bottom: 10px; }
  .q-card .q-text { font-family: 'Nunito', sans-serif; font-size: clamp(15px, 3.2vw, 21px); font-weight: 800; line-height: 1.35; }

  /* ANSWERS */
  .answers { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; }
  .ans-btn {
    border: none; border-radius: 16px; padding: 16px 14px;
    font-family: 'Nunito', sans-serif; font-size: clamp(12px, 2.4vw, 15px); font-weight: 800;
    color: #fff; cursor: pointer; text-align: left;
    display: flex; align-items: flex-start; gap: 9px;
    transition: transform .12s, filter .12s, opacity .2s;
    line-height: 1.3; min-height: 68px;
  }
  .ans-btn:hover:not(:disabled) { transform: scale(1.03); filter: brightness(1.1); }
  .ans-btn:active:not(:disabled) { transform: scale(.97); }
  .ans-btn .letter { background: rgba(0,0,0,.25); border-radius: 8px; min-width: 26px; height: 26px; display: flex; align-items: center; justify-content: center; font-size: 12px; flex-shrink: 0; margin-top: 1px; }
  .ans-btn.col-0 { background: #e74c3c; }
  .ans-btn.col-1 { background: #3498db; }
  .ans-btn.col-2 { background: #f39c12; }
  .ans-btn.col-3 { background: #27ae60; }
  .ans-btn.correct { background: #27ae60 !important; box-shadow: 0 0 0 3px #2ecc71; animation: pop .3s ease; }
  .ans-btn.wrong   { background: #7f8c8d !important; opacity: .5; }
  .ans-btn:disabled { cursor: default; }

  /* FEEDBACK */
  .feedback { border-radius: 14px; padding: 14px 18px; margin-bottom: 18px; font-family: 'Nunito', sans-serif; font-weight: 800; font-size: 15px; text-align: center; animation: slideUp .3s ease; display: none; }
  .feedback.show { display: block; }
  .feedback.ok { background: rgba(46,204,113,.2); border: 1px solid #2ecc71; color: #2ecc71; }
  .feedback.no { background: rgba(231,76,60,.2); border: 1px solid #e74c3c; color: #e74c3c; }

  .next-btn { display: none; width: 100%; padding: 15px; border: none; border-radius: 14px; background: linear-gradient(135deg, #e94560, #f5a623); color: #fff; font-family: 'Nunito', sans-serif; font-size: 17px; font-weight: 900; cursor: pointer; transition: transform .12s, filter .12s; }
  .next-btn.show { display: block; animation: fadeIn .3s ease; }
  .next-btn:hover { transform: scale(1.02); filter: brightness(1.08); }

  /* RESULT */
  #result { text-align: center; animation: fadeIn .5s ease; }
  #result .trophy { font-size: 72px; margin-bottom: 12px; }
  #result h2 { font-family: 'Nunito', sans-serif; font-size: 32px; font-weight: 900; margin-bottom: 6px; }
  #result .final-score { font-size: 52px; font-family: 'Nunito', sans-serif; font-weight: 900; background: linear-gradient(135deg, #f5a623, #e94560); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin: 16px 0; }
  #result .msg { color: var(--muted); font-size: 16px; margin-bottom: 12px; }
  .stats-row { display: flex; gap: 12px; justify-content: center; margin-bottom: 24px; }
  .stat-box { background: var(--card); border: 1px solid rgba(255,255,255,.08); border-radius: 14px; padding: 14px 20px; text-align: center; flex: 1; }
  .stat-box .sv { font-family: 'Nunito', sans-serif; font-size: 26px; font-weight: 900; }
  .stat-box .sl { font-size: 12px; color: var(--muted); margin-top: 3px; }
  .sv.green { color: #2ecc71; } .sv.red { color: #e74c3c; } .sv.yellow { color: #f5a623; }

  .review { text-align: left; background: var(--card); border: 1px solid rgba(255,255,255,.08); border-radius: 16px; padding: 20px 20px 8px; margin-bottom: 24px; }
  .review h3 { font-family: 'Nunito', sans-serif; font-size: 13px; font-weight: 800; color: var(--muted); text-transform: uppercase; letter-spacing: .06em; margin-bottom: 14px; }
  .review-item { display: flex; gap: 10px; margin-bottom: 14px; font-size: 13px; line-height: 1.4; }
  .review-item .icon { font-size: 17px; flex-shrink: 0; margin-top: 1px; }
  .review-item .qt { color: var(--muted); }
  .review-item .qa { color: #fff; font-weight: 600; margin-top: 2px; }

  .restart-btn { width: 100%; padding: 15px; border: none; border-radius: 14px; background: linear-gradient(135deg, #e94560, #f5a623); color: #fff; font-family: 'Nunito', sans-serif; font-size: 17px; font-weight: 900; cursor: pointer; transition: transform .12s; }
  .restart-btn:hover { transform: scale(1.02); }
  .hidden { display: none !important; }

  @keyframes fadeIn { from { opacity:0; transform: translateY(10px); } to { opacity:1; transform: translateY(0); } }
  @keyframes slideUp { from { opacity:0; transform: translateY(8px); } to { opacity:1; transform: translateY(0); } }
  @keyframes pop { 0%,100%{transform:scale(1)} 50%{transform:scale(1.06)} }

  @media (max-width: 480px) {
    .answers { grid-template-columns: 1fr; }
    .stats-row { flex-direction: column; }
  }
</style>
</head>
<body>
<div class="wrap">

<!-- SPLASH -->
<div id="splash">
  <div class="emoji">🇧🇷</div>
  <h1>Quiz<br>O Povo Brasileiro</h1>
  <p>Teste seus conhecimentos sobre a formação do povo brasileiro!</p>
  <div class="tag-row">
    <span class="tag tag-ind">🏹 Povos Indígenas</span>
    <span class="tag tag-afr">✊ Raiz Africana</span>
    <span class="tag tag-eur">⚓ Imigração Europeia</span>
    <span class="tag tag-asi">🌸 Imigração Asiática</span>
  </div>
  <div class="info-box">
    <div><span class="icon">❓</span><span><strong>20 perguntas</strong> de múltipla escolha</span></div>
    <div><span class="icon">⏱️</span><span><strong>45 segundos</strong> por pergunta</span></div>
    <div><span class="icon">⭐</span><span>Respostas rápidas valem <strong>mais pontos!</strong></span></div>
    <div><span class="icon">📚</span><span>4 temas do livro didático</span></div>
  </div>
  <button class="restart-btn" onclick="startQuiz()">🚀 Começar Quiz!</button>
</div>

<!-- QUIZ -->
<div id="quiz" class="hidden">
  <div class="progress-wrap"><div class="progress-bar" id="progressBar" style="width:0%"></div></div>
  <div class="top-bar">
    <div class="q-counter" id="qCounter">Pergunta 1 de 20</div>
    <div class="score-badge">⭐ <span id="scoreDisplay">0</span> pts</div>
  </div>
  <div class="timer-num" id="timerNum">20</div>
  <div class="timer-wrap"><div class="timer-bar" id="timerBar"></div></div>
  <div class="q-card">
    <div class="q-emoji" id="qEmoji"></div>
    <div id="catBadge"></div>
    <div class="q-text" id="qText"></div>
  </div>
  <div class="answers" id="answers"></div>
  <div class="feedback" id="feedback"></div>
  <button class="next-btn" id="nextBtn" onclick="nextQuestion()">Próxima →</button>
</div>

<!-- RESULT -->
<div id="result" class="hidden">
  <div class="trophy" id="trophy">🏆</div>
  <h2 id="resultTitle"></h2>
  <div class="final-score" id="finalScore"></div>
  <p class="msg" id="resultMsg"></p>
  <div class="stats-row">
    <div class="stat-box"><div class="sv green" id="statRight">0</div><div class="sl">✅ Corretas</div></div>
    <div class="stat-box"><div class="sv red" id="statWrong">0</div><div class="sl">❌ Erradas</div></div>
    <div class="stat-box"><div class="sv yellow" id="statPct">0%</div><div class="sl">🎯 Aproveitamento</div></div>
  </div>
  <div class="review" id="review">
    <h3>📋 Revisão das Respostas</h3>
    <div id="reviewItems"></div>
  </div>
  <button class="restart-btn" onclick="restartQuiz()">🔄 Jogar Novamente</button>
</div>

</div>
<script>
const CAT = {
  ind: { label: '🏹 Povos Indígenas', bg: 'rgba(46,204,113,.2)', color: '#2ecc71' },
  afr: { label: '✊ Raiz Africana',   bg: 'rgba(231,76,60,.2)',  color: '#e74c3c' },
  eur: { label: '⚓ Imigração Europeia', bg: 'rgba(52,152,219,.2)', color: '#3498db' },
  asi: { label: '🌸 Imigração Asiática', bg: 'rgba(155,89,182,.2)', color: '#9b59b6' },
};

const questions = [
  // --- INDÍGENAS ---
  { cat:'ind', emoji:'🌎', text:'Por que os povos indígenas são chamados de "povos originários"?',
    opts:['Porque criaram a língua portuguesa','Porque são os primeiros habitantes do Brasil','Porque vieram da Europa antes dos portugueses','Porque inventaram a escrita no Brasil'], correct:1,
    exp:'Os povos indígenas são chamados de povos originários porque são os primeiros habitantes do território brasileiro.' },
  { cat:'ind', emoji:'📊', text:'Quantos indígenas de quantos povos diferentes havia quando os portugueses chegaram ao Brasil?',
    opts:['1 milhão de 200 povos','3 milhões de 500 povos','5 milhões de 1.440 povos','10 milhões de 800 povos'], correct:2,
    exp:'Estima-se que havia cerca de 5 milhões de indígenas pertencentes a 1.440 povos diferentes.' },
  { cat:'ind', emoji:'🏘️', text:'Como são construídas as aldeias dos Yanomami?',
    opts:['Em cidades às margens dos rios','Em clareiras na Floresta Amazônica','Em montanhas e serras do Nordeste','Em ilhas no oceano Atlântico'], correct:1,
    exp:'As aldeias dos Yanomami costumam ser construídas em clareiras no meio da Floresta Amazônica.' },
  { cat:'ind', emoji:'🗺️', text:'Em quais estados brasileiros vivem principalmente os Yanomami?',
    opts:['Bahia e Minas Gerais','Pará e Amapá','Amazonas e Roraima','Mato Grosso e Tocantins'], correct:2,
    exp:'Os Yanomami vivem principalmente nos estados do Amazonas e Roraima, no Norte do Brasil.' },
  { cat:'ind', emoji:'🌐', text:'Além do Brasil, em qual país também vivem os Yanomami?',
    opts:['Colômbia','Peru','Bolívia','Venezuela'], correct:3,
    exp:'Os Yanomami vivem no Brasil e também na Venezuela. São cerca de 35 mil pessoas no total.' },
  { cat:'ind', emoji:'😔', text:'Qual é uma das principais dificuldades enfrentadas pelos povos indígenas hoje?',
    opts:['Excesso de moradia e comida','Invasão de terras e difícil acesso à saúde','Falta de festas tradicionais','Problemas com sinal de internet'], correct:1,
    exp:'Os povos indígenas enfrentam muitas dificuldades como a invasão de suas terras e o difícil acesso à saúde e à educação.' },
  { cat:'ind', emoji:'🔄', text:'O que é o Moitará, praticado pelos Yawalapiti do Parque Indígena do Xingu?',
    opts:['Uma dança ritual de guerra','Uma cerimônia de batismo','Uma troca ou escambo de artesanato e produtos','Um festival de música indígena'], correct:2,
    exp:'O Moitará é um evento em que ocorre troca ou escambo de artesanato e outros produtos entre os Yawalapiti.' },
  // --- AFRICANA ---
  { cat:'afr', emoji:'✊', text:'O Brasil é considerado a segunda maior nação negra do mundo. Qual país está em primeiro lugar?',
    opts:['África do Sul','Etiópia','Nigéria','Congo'], correct:2,
    exp:'O Brasil é considerado a segunda maior nação negra do mundo, ficando atrás apenas da Nigéria.' },
  { cat:'afr', emoji:'⛓️', text:'Quando o Brasil aboliu o trabalho escravo?',
    opts:['Em 1808','Em 1850','Em 1888','Em 1922'], correct:2,
    exp:'O Brasil foi um dos últimos países do mundo a proibir o trabalho escravo; isso ocorreu em 1888.' },
  { cat:'afr', emoji:'⛵', text:'A partir de quando os primeiros africanos chegaram ao Brasil como escravizados?',
    opts:['Século XIV','Século XV','Século XVI','Século XVII'], correct:2,
    exp:'Os primeiros africanos chegaram ao Brasil ainda no século XVI, trazidos à força de suas terras e escravizados.' },
  { cat:'afr', emoji:'🏰', text:'O Quilombo dos Palmares foi formado em 1597. Onde ele estava localizado?',
    opts:['Serra Gaúcha (RS)','Serra da Barriga (AL)','Serra do Mar (SP)','Serra do Espinhaço (MG)'], correct:1,
    exp:'Em 1597, quarenta africanos escravizados fugiram de um engenho em Alagoas e formaram o Quilombo dos Palmares, localizado na Serra da Barriga.' },
  { cat:'afr', emoji:'👑', text:'Quem era Ganga Zumba no Quilombo dos Palmares?',
    opts:['Um guerreiro que atacou Palmares','O primeiro rei de Palmares','Um governador português','O fundador do Dia da Consciência Negra'], correct:1,
    exp:'Ganga Zumba foi o primeiro rei de Palmares. Após sua morte, Zumbi assumiu o posto de rei.' },
  { cat:'afr', emoji:'🕯️', text:'Por que o dia 20 de novembro é o Dia Nacional da Consciência Negra?',
    opts:['Foi o dia em que os africanos chegaram ao Brasil','Foi o dia em que a escravidão foi abolida','Foi o dia em que Zumbi dos Palmares foi morto, em 1695','Foi o dia do nascimento de Ganga Zumba'], correct:2,
    exp:'O último rei de Palmares, Zumbi, foi morto em 20 de novembro de 1695. Em sua homenagem, essa data tornou-se o Dia Nacional da Consciência Negra.' },
  { cat:'afr', emoji:'🥁', text:'A presença africana foi decisiva na formação cultural brasileira, especialmente em:',
    opts:['Arquitetura e tecnologia','Música, dança, religiosidade e culinária','Agricultura industrial e comércio','Língua e escrita formal'], correct:1,
    exp:'A presença africana foi decisiva na formação cultural brasileira: na música, na dança, na religiosidade, na culinária e em outros setores.' },
  // --- EUROPEIA ---
  { cat:'eur', emoji:'🇵🇹', text:'Qual foi a principal herança que os portugueses deixaram para o Brasil?',
    opts:['A arquitetura em madeira','A língua portuguesa','O sistema de quilombos','A capoeira'], correct:1,
    exp:'Herdamos dos portugueses nosso idioma: a língua portuguesa.' },
  { cat:'eur', emoji:'📈', text:'Segundo o gráfico do livro, quais foram os três maiores grupos de imigrantes no Brasil entre 1884 e 1940?',
    opts:['Alemães, russos e árabes','Italianos, portugueses e espanhóis','Japoneses, italianos e ingleses','Poloneses, franceses e suíços'], correct:1,
    exp:'De acordo com o gráfico, os três maiores grupos de imigrantes no período foram italianos, portugueses e espanhóis.' },
  { cat:'eur', emoji:'🗓️', text:'Em que período houve entrada maciça de imigrantes europeus de vários países no Brasil?',
    opts:['Início do século XVI','Início do século XVIII','Segunda metade do século XIX e início do XX','Meados do século XX'], correct:2,
    exp:'Depois da segunda metade do século XIX, houve a entrada maciça de imigrantes de outros países no Brasil: italianos, portugueses, espanhóis, japoneses, alemães, russos, entre outros.' },
  // --- ASIÁTICA ---
  { cat:'asi', emoji:'🌸', text:'Quando teve início o movimento de imigrantes japoneses para o Brasil?',
    opts:['Em 1888','Em 1900','Em 1908','Em 1920'], correct:2,
    exp:'O movimento de imigrantes japoneses para o Brasil teve início em 1908, quando o navio Kasato Maru trouxe a bordo 165 famílias japonesas.' },
  { cat:'asi', emoji:'☕', text:'Em que tipo de atividade trabalharam os japoneses ao chegarem ao Brasil?',
    opts:['Construção de estradas e ferrovias','Comércio nas cidades do Rio de Janeiro','Nas fazendas de café do estado de São Paulo','Na pesca no litoral do Nordeste'], correct:2,
    exp:'Os imigrantes japoneses vieram, na sua maioria, para trabalhar nas fazendas de café do estado de São Paulo.' },
  { cat:'asi', emoji:'🌍', text:'Quais povos de origem asiática se destacaram na formação do povo brasileiro?',
    opts:['Chineses e coreanos','Japoneses e árabes (sírios e libaneses)','Indianos e tailandeses','Vietnamitas e mongóis'], correct:1,
    exp:'Os povos de origem asiática que se destacaram na formação do povo brasileiro foram os japoneses e os árabes, como sírios e libaneses.' },
];

let currentQ = 0, score = 0, timeLeft = 20, timerInterval = null, answered = false;
let history = [], correctCount = 0;

function startQuiz() {
  currentQ = 0; score = 0; history = []; correctCount = 0;
  document.getElementById('splash').classList.add('hidden');
  document.getElementById('result').classList.add('hidden');
  document.getElementById('quiz').classList.remove('hidden');
  renderQuestion();
}

function renderQuestion() {
  answered = false; timeLeft = 45;
  const q = questions[currentQ];
  const total = questions.length;

  document.getElementById('progressBar').style.width = (currentQ / total * 100) + '%';
  document.getElementById('qCounter').textContent = `Pergunta ${currentQ+1} de ${total}`;
  document.getElementById('scoreDisplay').textContent = score;
  document.getElementById('qEmoji').textContent = q.emoji;
  document.getElementById('qText').textContent = q.text;

  const cat = CAT[q.cat];
  const badge = document.getElementById('catBadge');
  badge.innerHTML = `<span class="cat-badge" style="background:${cat.bg};color:${cat.color};border:1px solid ${cat.color}">${cat.label}</span>`;

  ['feedback','nextBtn'].forEach(id => { const el = document.getElementById(id); el.className = el.tagName === 'BUTTON' ? 'next-btn' : 'feedback'; if(id==='feedback') el.textContent=''; });

  const colors = ['col-0','col-1','col-2','col-3'];
  const labels = ['A','B','C','D'];
  const answersEl = document.getElementById('answers');
  answersEl.innerHTML = '';
  q.opts.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = `ans-btn ${colors[i]}`;
    btn.innerHTML = `<span class="letter">${labels[i]}</span><span>${opt}</span>`;
    btn.onclick = () => selectAnswer(i);
    answersEl.appendChild(btn);
  });

  startTimer();
}

function startTimer() {
  clearInterval(timerInterval);
  updateTimerUI();
  timerInterval = setInterval(() => {
    timeLeft--;
    updateTimerUI();
    if (timeLeft <= 0) { clearInterval(timerInterval); if (!answered) timeUp(); }
  }, 1000);
}

function updateTimerUI() {
  const num = document.getElementById('timerNum');
  const bar = document.getElementById('timerBar');
  num.textContent = timeLeft;
  bar.style.width = (timeLeft / 45 * 100) + '%';
  num.style.color = timeLeft <= 5 ? '#e74c3c' : timeLeft <= 10 ? '#f5a623' : '#fff';
}

function selectAnswer(idx) {
  if (answered) return;
  answered = true;
  clearInterval(timerInterval);
  const q = questions[currentQ];
  const btns = document.querySelectorAll('.ans-btn');
  btns.forEach(b => b.disabled = true);
  const correct = idx === q.correct;
  const pts = correct ? Math.max(100, Math.round(100 + timeLeft * 15)) : 0;
  score += pts;
  if (correct) correctCount++;
  history.push({ q: q.text, correct, correctOpt: q.opts[q.correct] });
  btns[q.correct].classList.add('correct');
  if (!correct) btns[idx].classList.add('wrong');
  const fb = document.getElementById('feedback');
  if (correct) { fb.className = 'feedback ok show'; fb.textContent = `✅ Correto! +${pts} pontos`; }
  else { fb.className = 'feedback no show'; fb.textContent = `❌ Incorreto! Resposta: ${q.opts[q.correct]}`; }
  document.getElementById('scoreDisplay').textContent = score;
  document.getElementById('nextBtn').className = 'next-btn show';
}

function timeUp() {
  answered = true;
  const q = questions[currentQ];
  const btns = document.querySelectorAll('.ans-btn');
  btns.forEach(b => b.disabled = true);
  btns[q.correct].classList.add('correct');
  history.push({ q: q.text, correct: false, correctOpt: q.opts[q.correct] });
  const fb = document.getElementById('feedback');
  fb.className = 'feedback no show';
  fb.textContent = `⏰ Tempo esgotado! Resposta: ${q.opts[q.correct]}`;
  document.getElementById('nextBtn').className = 'next-btn show';
}

function nextQuestion() {
  currentQ++;
  if (currentQ >= questions.length) showResult();
  else renderQuestion();
}

function showResult() {
  document.getElementById('quiz').classList.add('hidden');
  document.getElementById('result').classList.remove('hidden');
  const total = questions.length;
  const pct = correctCount / total;
  let trophy='🥉', title='Continue estudando!', msg='Revise o conteúdo e tente novamente!';
  if (pct >= .85) { trophy='🏆'; title='Excelente!'; msg='Você arrasou! Conhece muito bem o povo brasileiro!'; }
  else if (pct >= .65) { trophy='🥈'; title='Muito bom!'; msg='Quase lá! Revise mais alguns pontos.'; }
  else if (pct >= .4)  { trophy='🥉'; title='Bom esforço!'; msg='Continue estudando — você está no caminho certo!'; }

  document.getElementById('trophy').textContent = trophy;
  document.getElementById('resultTitle').textContent = title;
  document.getElementById('finalScore').textContent = score + ' pts';
  document.getElementById('resultMsg').textContent = msg;
  document.getElementById('statRight').textContent = correctCount;
  document.getElementById('statWrong').textContent = total - correctCount;
  document.getElementById('statPct').textContent = Math.round(pct * 100) + '%';

  const ri = document.getElementById('reviewItems');
  ri.innerHTML = '';
  history.forEach((h, i) => {
    const div = document.createElement('div');
    div.className = 'review-item';
    div.innerHTML = `<span class="icon">${h.correct ? '✅' : '❌'}</span><div><div class="qt">${i+1}. ${h.q}</div><div class="qa">✔ ${h.correctOpt}</div></div>`;
    ri.appendChild(div);
  });
}

function restartQuiz() {
  document.getElementById('result').classList.add('hidden');
  document.getElementById('splash').classList.remove('hidden');
}
</script>
